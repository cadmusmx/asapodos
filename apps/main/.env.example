# Ensure your .env has:
# - NEXTAUTH_SECRET (generate with openssl rand -base64 32) — MUST be unique per app
# - DATABASE_URL (e.g., file:./dev.db for SQLite)

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
BASEPATH=
NEXT_PUBLIC_APP_URL=http://localhost:3000${BASEPATH}
NEXT_PUBLIC_DOCS_URL=https://demos.themeselection.com/marketplace/materio-mui-nextjs-admin-template/documentation

# -----------------------------------------------------------------------------
# App movil
# -----------------------------------------------------------------------------
MOBILE_JWT_SECRET=Gd$AamS9dOy7Fdya%AR2026

# -----------------------------------------------------------------------------
# Authentication (NextAuth.js)
# -----------------------------------------------------------------------------
NEXTAUTH_BASEPATH=${BASEPATH}/api/auth
NEXTAUTH_URL=http://localhost:3000${BASEPATH}/api/auth
NEXTAUTH_SECRET=16cYmUoVzh0V/6fuIBvUvcuFJbp00wmwKjuc+3ZQDiQ=  # generate: openssl rand -base64 32

# Google OAuth 2.0 (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
